# Cancer Treatment Schedule Service - EnvironmentFile template
#
# Install:
#   sudo mkdir -p /etc/cancer-treatment
#   sudo cp scripts/cancer-treatment.env.example /etc/cancer-treatment/cancer-treatment.env
#   sudo chown root:cancer /etc/cancer-treatment/cancer-treatment.env
#   sudo chmod 640 /etc/cancer-treatment/cancer-treatment.env
#   # Edit values below
#
# Notes:
#   - systemd EnvironmentFile does NOT interpret shell syntax. No quotes around values.
#   - Do NOT commit real secrets to git. This file is .example only.

# ── Profile / Port ─────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
CANCER_TREATMENT_PORT=8083

# ── Database (production MySQL) ────────────────────────
CANCER_TREATMENT_DATASOURCE_URL=jdbc:mysql://<PROD_DB_HOST>:3306/csm?serverTimezone=Asia/Seoul&useSSL=true&characterEncoding=UTF-8
CANCER_TREATMENT_DATASOURCE_USERNAME=<PROD_DB_USER>
CANCER_TREATMENT_DATASOURCE_PASSWORD=<PROD_DB_PASSWORD>

# Tables already exist in production → never. Set to `always` only for first-time bootstrap.
CANCER_TREATMENT_SQL_INIT_MODE=never

# ── SSO (must match mediplat / csm) ────────────────────
COUNSELMAN_MEDIPLAT_SSO_SHARED_SECRET=<SAME_VALUE_AS_MEDIPLAT_AND_CSM>
CANCER_TREATMENT_SSO_ALLOWED_CLOCK_SKEW_SECONDS=60

# ── External URLs ──────────────────────────────────────
# Where the mediplat portal lives (used to redirect back on logout)
CANCER_TREATMENT_MEDIPLAT_PORTAL_URL=https://<MEDIPLAT_DOMAIN>/portal
